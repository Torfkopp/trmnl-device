<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>7-Tage Kalender</title>
  <style>
    :root{
      /* --bg:#ffffff;
      --card:#f8f9fa;
      --text:#111827;
      --muted:#6b7280; */
      font-family: Arial, sans-serif;
    }
    *{box-sizing:border-box}

    .wrapper{
      width:800px;
      height:480px;
      background:var(--bg);
      display:flex;
      flex-direction:column;
    }

    .calendar-grid{
      display:grid;
      grid-template-columns:repeat(7,1fr);
      flex:1;
      border-top:1px solid #e5e7eb;
      border-bottom:1px solid #e5e7eb;
    }
    .day{
      border-right:1px solid #000000;
      display:flex;
      flex-direction:column;
      padding:6px;
    }
    .day:last-child{border-right:none}

    .day-header{
      border-bottom:1px solid #000000;
      padding-bottom:6px;
      margin-bottom:6px;
      text-align:center;
    }
    .weekday{
      font-weight:700;
      font-size:16px;
      margin-bottom:2px;
    }
    .date{
      font-size:14px;
      color:var(--muted);
    }

    .weekend {
      background: linear-gradient(0deg, #FFF 89.5%, #000000 11%);
      color: #ffffff;
    }

    .timed-event, .all-day-event{
      padding:6px 8px;
      margin-bottom:6px;
      border-left:4px solid transparent;
      border-radius:6px;
      font-size:16px;
      line-height:1.4;
    }
    .event-time{font-size:15px;color:var(--muted);font-weight:600;margin-right:4px}
    .summary{font-weight:500}

    .all-day-event[data-kind="private"] {
      background: #000000;
      color: #ffffff;
    }
    .all-day-event[data-kind="football"] {
      background: #333;
      color: #ffffff;
    }
    .all-day-event[data-kind="feiertage"] {
      background: #000000;
      color: #ffffff;
    }
    .timed-event[data-kind="feiertage"] {
      background: #000000;
      color: #ffffff;
    }
    .timed-event[data-kind="private"] {
      background: #bdbdbd;
      color: #000000;
    }
    .timed-event[data-kind="football"] {
      background: #eee;
      color: #000000;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div id="calendar" class="calendar-grid" aria-live="polite"></div>
  </div>

  <script>
    const TIMEZONE = 'Europe/Berlin';

    function formatDayHeader(date){
      const weekday = new Intl.DateTimeFormat('de-DE', { weekday: 'long', timeZone: TIMEZONE }).format(date);
      const day = new Intl.DateTimeFormat('de-DE', { day: '2-digit', month: 'short', timeZone: TIMEZONE }).format(date);
      return `<div class="weekday">${weekday}</div><div class="date">${day}</div>`;
    }
    function formatTime(date){
      return new Intl.DateTimeFormat('de-DE',{hour:'2-digit',minute:'2-digit',timeZone:TIMEZONE}).format(date);
    }

    function endOfDay(date){return new Date(date.getFullYear(), date.getMonth(), date.getDate(), 23,59,59);}

    async function loadAndRender(){
      let events=[];
      const res=await fetch('http://192.168.178.101:8000/weekly.json');
      events=await res.json();

      const today=new Date().toLocaleDateString(['sv-SE'], { timeZone: TIMEZONE }).split("-");
      const days=[];
      for(let i=0;i<7;i++){
        const d = new Date(today[0], parseInt(today[1]) - 1, parseInt(today[2]) + i);
        days.push({ date: d, allDayEvents: [], timedEvents: [] });
      }

      for (const ev of events) {
        const s = (new Date(ev.start)).toLocaleDateString(['sv-SE'], { timeZone: TIMEZONE });
        const e = (new Date(ev.end)).toLocaleDateString(['sv-SE'], { timeZone: TIMEZONE });
        for (const d of days) {
          var da = d.date.toLocaleDateString(['sv-SE'], { timeZone: TIMEZONE });
          if (s == da || e == da) {
            (ev.all_day ? d.allDayEvents : d.timedEvents).push(ev);
          }
        }
      }

      const cal=document.getElementById('calendar');
      cal.innerHTML='';

      days.forEach(d=>{
  const day=document.createElement('div');
  // Weekend: Sunday (0) or Saturday (6)
  const isWeekend = d.date.getDay() === 0 || d.date.getDay() === 6;
  day.className = 'day' + (isWeekend ? ' weekend' : '');

  // Header centered
  const header=document.createElement('div');
  header.className='day-header';
  header.innerHTML=formatDayHeader(d.date);
  day.appendChild(header);

        // All-day events first
        d.allDayEvents.forEach(ev=>{
          const div=document.createElement('div');
          div.className=`all-day-event`;
          div.dataset.kind = ev.kind || 'default';
          div.textContent=ev.summary;
          day.appendChild(div);
        });

        // Timed events
        d.timedEvents.forEach(ev=>{
          const div=document.createElement('div');
          div.className=`timed-event`;
          div.dataset.kind = ev.kind || 'default';
          div.innerHTML=`<span class="event-time">${formatTime(new Date(ev.start))}–${formatTime(new Date(ev.end))}</span><span class="summary"> ${ev.summary}</span>`;
          day.appendChild(div);
        });

        cal.appendChild(day);
      });
    }

    loadAndRender();
  </script>
</body>
</html>
