<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Simple Calendar</title>

  <style>
    :root {
      --bg: #f7f7f9;
      --card: #fff;
      --muted: #666;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      width: 800px;
      height: 480px;
      overflow: hidden;
      font-family: Arial, sans-serif;
      background: var(--bg);
    }

    .calendar {
      width: 800px;
      height: 480px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* smaller header row */
    .weekdays {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      border-bottom: 1px solid #ccc;
      flex-shrink: 0;
    }

    .weekday {
      font-size: 12px;
      font-weight: bold;
      text-align: center;
      padding: 2px 0;
      line-height: 1;
    }

    .weeks {
      flex: 1;
      display: grid;
      grid-template-rows: repeat(6, 1fr);
      overflow: hidden;
      border-left: 1px solid #eee;
    }

    .week {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      border-top: 1px solid #eee;
    }

    .week:last-child {
      border-bottom: 1px solid #eee;
    }

    .day {
      border-right: 1px solid #eee;
      font-size: 12px;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      padding: 1px;
    }

    .day.in-month .date {
      font-weight: 600;
    }

    .day.out-month .date {
      color: #000000;
    }

    .day.today {
      border: 2px solid black;
    }

    /* smaller date badge */
    .date {
      display: inline-block;
      padding: 0 3px;
      border-radius: 4px;
      font-size: 11px;
      line-height: 1.1;
      margin-bottom: 1px;
    }

    .event-seg {
      margin-top: 1px;
      border-radius: 3px;
      padding: 1px 3px;
      font-size: 11px;
      line-height: 1.1;
      color: white;
      width: 100%;

      /* limit to 2 lines */
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;

      word-break: break-word;
    }

    .event-seg[data-kind="private"][data-all-day="true"] {
      background: #000000;
    }

    .event-seg[data-kind="private"][data-all-day="false"] {
      background: #bdbdbd;
      color: #000000;
    }

    .event-seg[data-kind="feiertage"] {
      background: #333;
    }

    .event-seg[data-kind="football"][data-all-day="true"] {
      background: #333;
    }

    .event-seg[data-kind="football"][data-all-day="false"] {
      background: #eee;
      color: #000000;
    }
  </style>
</head>

<body>
  <div class="calendar">
    <div class="weekdays" id="weekdays"></div>
    <div class="weeks" id="weeks"></div>
  </div>

  <script>
    async function fetchEvents() {
      const res = await fetch('http://192.168.178.101:8000/monthly.json');
      return await res.json();
    }

    function parseISOToDate(iso) {
      if (!iso) return null;
      return new Date(iso.replace(' ', 'T'));
    }

    function startOfWeekMonday(d) {
      const dt = new Date(d);
      const day = (dt.getDay() + 6) % 7;
      dt.setDate(dt.getDate() - day);
      dt.setHours(0, 0, 0, 0);
      return dt;
    }

    function addDays(d, n) {
      const x = new Date(d);
      x.setDate(x.getDate() + n);
      x.setHours(0, 0, 0, 0);
      return x;
    }

    function buildWeeksForMonth(year, month) {
      const firstOfMonth = new Date(year, month, 1);
      const firstWeekStart = startOfWeekMonday(firstOfMonth);

      const weeks = [];
      let wkStart = new Date(firstWeekStart);

      for (let w = 0; w < 6; w++) {
        const days = [];

        for (let d = 0; d < 7; d++) {
          days.push(addDays(wkStart, d));
        }

        weeks.push({
          start: new Date(wkStart),
          days
        });

        wkStart = addDays(wkStart, 7);
      }

      return weeks;
    }

    function renderCalendar(events) {
      const now = new Date();
      now.setHours(0, 0, 0, 0);

      const year = now.getFullYear();
      const month = now.getMonth();

      const weekdaysEl = document.getElementById('weekdays');

      const shortDays = [];

      for (let i = 0; i < 7; i++) {
        const tmp = new Date(2020, 0, 6 + i);

        shortDays.push(
          tmp.toLocaleString("de-DE", {
            weekday: 'short'
          })
        );
      }

      weekdaysEl.innerHTML = shortDays
        .map(d => `<div class="weekday">${d}</div>`)
        .join('');

      const weeks = buildWeeksForMonth(year, month);

      const weeksEl = document.getElementById('weeks');
      weeksEl.innerHTML = '';

      const eventsByDate = {};

      events.forEach(ev => {
        const start = parseISOToDate(ev.start);
        const end = parseISOToDate(ev.end);

        const iter = new Date(start);
        const endDate = new Date(end);

        while (iter <= endDate) {
          const key = iter
            .toLocaleString(["sv-SE"], {
              timeZone: 'Europe/Berlin'
            })
            .slice(0, 10);

          if (!eventsByDate[key]) {
            eventsByDate[key] = [];
          }

          eventsByDate[key].push(ev);

          iter.setDate(iter.getDate() + 1);
        }
      });

      weeks.forEach(wk => {
        const wkEl = document.createElement('div');
        wkEl.className = 'week';

        wk.days.forEach(day => {
          const inMonth = (day.getMonth() === month);

          const key = day
            .toLocaleString(["sv-SE"], {
              timeZone: 'Europe/Berlin'
            })
            .slice(0, 10);

          const dayEl = document.createElement('div');

          dayEl.className =
            'day ' + (inMonth ? 'in-month' : 'out-month');

          if (day.getTime() === now.getTime()) {
            dayEl.classList.add('today');
          }

          dayEl.innerHTML =
            `<div class="date">${day.getDate()}</div>`;

          const dayEvents = eventsByDate[key] || [];

          dayEvents.forEach(ev => {
            const segEl = document.createElement('div');

            segEl.className = 'event-seg';
            segEl.dataset.allDay =
              ev.all_day ? 'true' : 'false';

            segEl.dataset.kind =
              ev.kind || 'default';

            const startDate = parseISOToDate(ev.start);

            segEl.textContent = ev.all_day
              ? ev.summary
              : `${startDate.toLocaleTimeString(
                  ["de-DE"],
                  {
                    hour: '2-digit',
                    minute: '2-digit',
                    timeZone: "Europe/Berlin"
                  }
                )} ${ev.summary}`;

            dayEl.appendChild(segEl);
          });

          wkEl.appendChild(dayEl);
        });

        weeksEl.appendChild(wkEl);
      });
    }

    (async function () {
      const events = await fetchEvents();
      renderCalendar(events);
    })();
  </script>
</body>
